# PostgreSQL
POSTGRES_DB=kfs
POSTGRES_USER=kfs
POSTGRES_PASSWORD=kfs
POSTGRES_PORT=5432

# API
ASPNETCORE_ENVIRONMENT=Production
API_PORT=5080
JWT_ISSUER=kfs
JWT_AUDIENCE=kfs-clients
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
QR_ISSUER=kfs-qr
QR_SIGNING_KEY=replace-this-with-a-different-long-random-secret-32+chars
SUPER_ADMIN_PASSWORD=Admin@123
SWAGGER_ENABLED=true

# Frontend origins
WEB_PORTAL_ORIGIN=http://localhost:5173
WEB_ADMIN_ORIGIN=http://localhost:5174
WEB_SCANNER_ORIGIN=http://localhost:5175
