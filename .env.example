# PostgreSQL
POSTGRES_DB=kfsbooking
POSTGRES_USER=kfsbooking
POSTGRES_PASSWORD=kfsbooking
POSTGRES_PORT=5432

# API
ASPNETCORE_ENVIRONMENT=Production
API_PORT=5080
JWT_ISSUER=kfsbooking
JWT_AUDIENCE=kfsbooking-clients
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_MINUTES=480
SWAGGER_ENABLED=true

# Web
WEB_PORT=8080
WEB_ORIGIN=http://localhost:8080
