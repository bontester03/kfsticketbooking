{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=kfs;Username=kfs;Password=kfs"
  },
  "Jwt": {
    "Issuer": "kfs",
    "Audience": "kfs-clients",
    "Secret": "change-me-to-a-long-random-secret-at-least-32-chars",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Qr": {
    "Issuer": "kfs-qr",
    "SigningKey": "change-me-separate-from-jwt-32+chars-please"
  },
  "Auth": {
    "SuperAdminPassword": "Admin@123"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost"
    ]
  },
  "Database": { "RunMigrationsOnStartup": true },
  "Swagger": { "Enabled": true },
  "Storage": {
    "Provider": "LocalDisk",
    "LocalRoot": "",
    "PublicBase": "/static",
    "Container": "qr-codes",
    "SasLifetimeMinutes": 5
  },
  "Email": {
    "Provider": "Console"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
