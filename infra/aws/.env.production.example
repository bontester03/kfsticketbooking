# Copy to .env on the EC2 and fill in. NEVER commit the filled file.

# ---- Hostnames (must have DNS A records pointing at the EC2's public IP) ----
KFS_HOST_PORTAL=kfs.example.com
KFS_HOST_ADMIN=admin.kfs.example.com
KFS_HOST_SCANNER=scan.kfs.example.com
ACME_EMAIL=admin@example.com         # for Let's Encrypt renewal notices

# ---- Database (Postgres in Docker on this EC2; can later be swapped for RDS) ----
POSTGRES_DB=kfs
POSTGRES_USER=kfs
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
POSTGRES_PORT=5432

# ---- API ----
ASPNETCORE_ENVIRONMENT=Production
API_PORT=5080
JWT_ISSUER=kfs
JWT_AUDIENCE=kfs-clients
JWT_SECRET=CHANGE_THIS_32+_CHAR_RANDOM
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
QR_ISSUER=kfs-qr
QR_SIGNING_KEY=CHANGE_THIS_DIFFERENT_32+_CHAR_RANDOM
SUPER_ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
SWAGGER_ENABLED=false

# ---- Frontend allowed origins (auto-set in the compose override) ----
WEB_PORTAL_ORIGIN=https://kfs.example.com
WEB_ADMIN_ORIGIN=https://admin.kfs.example.com
WEB_SCANNER_ORIGIN=https://scan.kfs.example.com

# ---- Email (Gmail Workspace via App Password) ----
EMAIL_PROVIDER=Smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=graduation@kfs.sch.sa
EMAIL_PASSWORD=PASTE_16_CHAR_APP_PASSWORD_HERE
EMAIL_FROM=graduation@kfs.sch.sa
EMAIL_FROM_NAME=King Faisal School
EMAIL_PORTAL_URL=https://kfs.example.com
# Do NOT enable in production. The local-dev flag for corporate-proxy TLS.
EMAIL_ACCEPT_INVALID_CERT=false
