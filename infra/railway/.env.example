# Railway environment variables — paste these into each service's Variables tab.
#
# Railway gives every service its own variable scope. Postgres comes from the
# managed plugin (the DATABASE_URL is wired in via reference, not pasted).
#
# Generate the secrets with:
#   openssl rand -hex 32     # for JWT_SECRET, QR_SIGNING_KEY
#   openssl rand -hex 16     # for POSTGRES_PASSWORD (if you self-host PG)

# ============================================================================
# Service: api (the .NET backend)
# ============================================================================

# Wired automatically when you click "Add Variable Reference" → Postgres → DATABASE_URL.
# Our Program.cs translates the postgres:// URL to the Npgsql format.
# DATABASE_URL=${{ Postgres.DATABASE_URL }}

ASPNETCORE_ENVIRONMENT=Production
# Railway injects $PORT; Program.cs.NormalizePort picks it up. Don't set ASPNETCORE_URLS.

# JWT — long random strings, kept SEPARATE so leaking auth tokens can't forge QR codes.
Jwt__Issuer=kfs
Jwt__Audience=kfs-clients
Jwt__Secret=CHANGE_THIS_TO_64_HEX_CHARS_FROM_OPENSSL_RAND
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

Qr__Issuer=kfs-qr
Qr__SigningKey=CHANGE_THIS_DIFFERENT_64_HEX_CHARS_FROM_OPENSSL_RAND

Auth__SuperAdminPassword=CHANGE_THIS_TO_A_STRONG_PASSWORD

# CORS — the three URLs Railway assigned to portal/admin/scanner services.
# Copy them from each service's Settings → Networking → Public Domain.
Cors__AllowedOrigins__0=https://kfs-portal-production.up.railway.app
Cors__AllowedOrigins__1=https://kfs-admin-production.up.railway.app
Cors__AllowedOrigins__2=https://kfs-scanner-production.up.railway.app

# Email — Gmail Workspace App Password (same one that works locally).
Email__Provider=Smtp
Email__Host=smtp.gmail.com
Email__Port=587
Email__Username=graduation@kfs.sch.sa
Email__Password=YOUR_GMAIL_APP_PASSWORD
Email__FromAddress=graduation@kfs.sch.sa
Email__FromName=King Faisal School
Email__PortalUrl=https://kfs-portal-production.up.railway.app
Email__AcceptInvalidCert=false

# Database migrations on startup — fine for this project (one-DB single-writer).
Database__RunMigrationsOnStartup=true

Swagger__Enabled=false

# Storage — LocalDisk + a Railway Volume mounted at /app/wwwroot. See runbook.
Storage__Provider=LocalDisk
Storage__PublicBaseUrl=https://kfs-api-production.up.railway.app

# ============================================================================
# Services: portal, admin, scanner
# ============================================================================
# Each web service only needs ONE Railway variable: the API host.
# Use Railway's internal DNS (zero-cost, private, fast).

API_HOST=api.railway.internal
API_PORT=8080

# (No other vars needed — the React apps call /api/v1 which nginx proxies internally.)
