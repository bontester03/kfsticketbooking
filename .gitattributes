# Default to LF for text files; Git will normalize on commit and check-out per OS.
* text=auto eol=lf

# Files that MUST stay LF (consumed by Linux containers)
*.sh                text eol=lf
Dockerfile          text eol=lf
*.dockerfile        text eol=lf
*.conf              text eol=lf
*.template          text eol=lf

# Binary types
*.png               binary
*.jpg               binary
*.jpeg              binary
*.gif               binary
*.ico               binary
*.woff              binary
*.woff2             binary
